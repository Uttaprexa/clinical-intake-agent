# Copy this to .env and fill in real values. Never commit .env.

# LLM_PROVIDER controls which backend the pipeline uses -- no code changes needed.
#   mock      = free, no API key needed, heuristic responses (good for a first run)
#   ollama    = free, real local LLM via https://ollama.com (needs Ollama running)
#   anthropic = real Claude via API (costs a small amount of credit, most accurate)
LLM_PROVIDER=mock

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Only needed if LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clinical_intake
REDIS_URL=redis://localhost:6379/0

UPLOAD_DIR=/tmp/clinical-intake-uploads
CORS_ORIGINS=http://localhost:5173
